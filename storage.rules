rules_version = '2';
// Deploy with: firebase deploy --only storage
// Or paste into Firebase Console → Storage → Rules
service firebase.storage {
  match /b/{bucket}/o {
    // Existing bug report uploads (Support page)
    match /bug_reports/{reportId}/{fileName} {
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow read: if false; // Admin SDK only
    }

    // Business logos for quote/invoice PDFs
    match /business_logos/{userId}/{fileName} {
      allow read: if true; // public quote PDFs need to load the logo
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/(png|jpeg|webp)');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
